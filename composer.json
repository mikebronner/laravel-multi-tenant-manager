{
    "name": "genealabs/laravel-multi-tenant-manager",
    "description": "A Laravel package to manage multi-tenants.",
    "keywords": [
        "laravel"
    ],
    "license": "MIT",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/fabmade/multi-tenant"
        },
    ],
    "require": {
        "hyn/multi-tenant": "dev-5.x@dev",
        "illuminate/console": "^8.0",
        "illuminate/database": "^8.0",
        "illuminate/http": "^8.0",
        "illuminate/routing": "^8.0",
        "illuminate/support": "^8.0"
    },
    "require-dev": {
        "genealabs/php-coding-standards": "dev-main@dev"
    },
    "autoload": {
        "psr-4": {
            "GeneaLabs\\LaravelMultiTenantManager\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "GeneaLabs\\LaravelMultiTenantManager\\Providers\\Service"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
